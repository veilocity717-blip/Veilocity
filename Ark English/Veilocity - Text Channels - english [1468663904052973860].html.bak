    loading="lazy"
    class="chatlog__emoji "
    alt="🪙"
    title="coin"
    src="https://cdn.jsdelivr.net/gh/twitter/twemoji@latest/assets/svg/1fa99.svg"><img
    loading="lazy"
    class="chatlog__emoji "
    alt="🔐"
